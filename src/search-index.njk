---
permalink: /search-index.json
eleventyExcludeFromCollections: true
---
{% set entries = [] %}
{% for article in articles %}
{% for para in article.paragraphs %}
{% set chapter = chapters | findChapter(article.chapter) %}
{% set _ = entries.push({
  type: "article",
  article: article.number,
  paragraph: para.number,
  title: article.title,
  chapter: chapter.roman if chapter else "",
  chapterTitle: chapter.title if chapter else "",
  text: para.text,
  url: "/" + article.number + "/#" + para.number
}) %}
{% for sp in para.subpoints %}
{% set _ = entries.push({
  type: "article",
  article: article.number,
  paragraph: para.number,
  title: article.title,
  chapter: chapter.roman if chapter else "",
  chapterTitle: chapter.title if chapter else "",
  text: sp.label + " " + sp.text,
  url: "/" + article.number + "/#" + para.number
}) %}
{% endfor %}
{% endfor %}
{% endfor %}
{% for rec in recitals %}
{% set ref = rec.number | articleForRecital(recitalMap) %}
{% set _ = entries.push({
  type: "recital",
  number: rec.number,
  text: rec.text,
  articleRef: ref,
  url: "/r/#r" + rec.number
}) %}
{% endfor %}
{% for gk in gatekeepers %}
{% set svcNames = [] %}
{% for svc in gk.services %}
{% set _ = svcNames.push(svc.name) %}
{% endfor %}
{% set _ = entries.push({
  type: "gatekeeper",
  name: gk.name,
  text: gk.name + " — " + svcNames.join(", "),
  url: "/g/#" + gk.slug
}) %}
{% endfor %}
{{ entries | dump | safe }}
