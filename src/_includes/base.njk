<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if pageTitle %}{{ pageTitle }} — {% endif %}{{ site.title }}</title>
  <meta name="description" content="{{ pageDescription | default('Navigate the full text of the Digital Markets Act (EU Regulation 2022/1925) with linked recitals and easy article navigation.') }}">
  {# OpenGraph #}
  <meta property="og:title" content="{% if pageTitle %}{{ pageTitle }} — {% endif %}{{ site.title }}">
  <meta property="og:description" content="{{ pageDescription | default('Navigate the full text of the Digital Markets Act (EU Regulation 2022/1925) with linked recitals and easy article navigation.') }}">
  <meta property="og:url" content="https://digitalmarketsact.com{{ page.url }}">
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="{{ site.title }}">
  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content="{% if pageTitle %}{{ pageTitle }} — {% endif %}{{ site.title }}">
  <meta name="twitter:description" content="{{ pageDescription | default('Navigate the full text of the Digital Markets Act (EU Regulation 2022/1925) with linked recitals and easy article navigation.') }}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,600;1,6..72,400&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="min-h-screen bg-surface text-on-surface">
  <script>
    (function(){var d=localStorage.getItem('darkMode');if(d==='true'||(d===null&&window.matchMedia('(prefers-color-scheme:dark)').matches)){document.documentElement.classList.add('dark')}})();
  </script>
  {% include "header.njk" %}
  <main>
    {{ content | safe }}
  </main>
  {% include "footer.njk" %}
  <script src="/js/commands.js"></script>
</body>
</html>
