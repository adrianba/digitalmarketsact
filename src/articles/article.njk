---
pagination:
  data: articles
  size: 1
  alias: article
permalink: "/{{ article.number }}/"
layout: base.njk
eleventyComputed:
  pageTitle: "Article {{ article.number }}{% if article.title %} — {{ article.title }}{% endif %}"
---

{% set chapter = chapters | findChapter(article.chapter) %}
{% set prevArt = articles | prevArticle(article.number) %}
{% set nextArt = articles | nextArticle(article.number) %}

<div class="max-w-7xl mx-auto px-6 lg:px-10 py-8">
  {# Breadcrumb #}
  <nav class="mb-8">
    <ol class="flex items-center gap-2 font-label text-sm text-on-surface-variant">
      <li><a href="/" class="hover:text-primary transition-colors">Articles</a></li>
      <li class="text-outline-variant">/</li>
      {% if chapter %}
      <li><a href="/#chapter-{{ chapter.number }}" class="hover:text-primary transition-colors">Chapter {{ chapter.roman }}</a></li>
      <li class="text-outline-variant">/</li>
      {% endif %}
      <li class="text-on-surface font-medium">Article {{ article.number }}</li>
    </ol>
  </nav>

  <div class="flex flex-col lg:flex-row gap-10">
    {# Left sidebar — chapter articles nav #}
    <aside class="hidden lg:block w-52 shrink-0">
      <div class="sticky top-6">
        {% if chapter %}
        <a href="/#chapter-{{ chapter.number }}" class="block mb-4 hover:text-primary transition-colors">
          <p class="article-tag mb-1">Chapter {{ chapter.roman }}</p>
          <p class="font-headline font-semibold text-sm text-on-surface capitalize">{{ chapter.title | lower }}</p>
        </a>
        {% endif %}
        <nav id="sidebar-nav" class="flex flex-col gap-1 sidebar-scroll max-h-[70vh] overflow-y-auto">
          {% set sameChapterArticles = articles | articlesInChapter(article.chapter) %}
          {% for art in sameChapterArticles %}
          <a href="/{{ art.number }}/"
             class="font-label text-sm py-1.5 px-2 rounded-lg transition-colors
                    {% if art.number == article.number %}bg-primary-container text-on-primary-container font-medium
                    {% else %}text-on-surface-variant hover:text-primary hover:bg-surface-container{% endif %}"
             {% if art.number == article.number %}data-current{% endif %}>
            Art. {{ art.number }}{% if art.title %} <span class="text-xs opacity-75">{{ art.title }}</span>{% endif %}
          </a>
          {% endfor %}
        </nav>
        <script>
          var c = document.querySelector('#sidebar-nav [data-current]');
          if (c) c.scrollIntoView({ block: 'center' });
        </script>
      </div>
    </aside>

    {# Main content with inline recitals #}
    <article class="flex-1 min-w-0">
      {# Article header #}
      <header class="mb-8">
        <p class="article-tag mb-2">Article {{ article.number }}</p>
        {% if article.title %}
        <h1 class="font-headline font-bold text-2xl md:text-3xl text-on-surface" data-no-autolink>{{ article.title }}</h1>
        {% endif %}
      </header>

      {# Article body — each paragraph paired with its recitals #}
      {% for para in article.paragraphs %}
      {% set paraRecitals = article.number | recitalsForParagraph(para.number, recitalMap, recitals) %}
      <div class="mb-10 flex flex-col xl:flex-row gap-6 xl:gap-8" id="{{ para.number }}">
        {# Paragraph content #}
        <div class="legal-text flex-1 min-w-0">
          {% if para.html %}
          <div class="font-body text-on-surface leading-relaxed" data-permalink="/{{ article.number }}/#{{ para.number }}">
            {{ para.html | safe }}
          </div>
          {% endif %}

          {# Sub-points #}
          {% if para.subpoints.length > 0 %}
          <div class="mt-3 ml-6">
            {% for sp in para.subpoints %}
            <div class="mb-3 flex items-baseline gap-3">
              <span class="shrink-0 font-label text-sm text-primary font-medium w-8">{{ sp.label }}</span>
              <div class="font-body text-on-surface leading-relaxed">
                {% if sp.html %}{{ sp.html | safe }}{% endif %}
                {% if sp.subpoints.length > 0 %}
                <div class="mt-2 ml-4">
                  {% for ssp in sp.subpoints %}
                  <div class="mb-2 flex items-baseline gap-3">
                    <span class="shrink-0 font-label text-sm text-secondary font-medium w-8">{{ ssp.label }}</span>
                    <div class="font-body text-on-surface text-base leading-relaxed">
                      {% if ssp.html %}{{ ssp.html | safe }}{% endif %}
                    </div>
                  </div>
                  {% endfor %}
                </div>
                {% endif %}
              </div>
            </div>
            {% endfor %}
          </div>
          {% endif %}

          {# Closing text (appears after sub-points in some paragraphs) #}
          {% if para.closingHtml %}
          <div class="font-body text-on-surface leading-relaxed mt-3">
            {{ para.closingHtml | safe }}
          </div>
          {% endif %}
        </div>

        {# Inline recitals for this paragraph #}
        {% if paraRecitals.length > 0 %}
        <div class="xl:w-56 shrink-0 flex flex-col gap-3">
          {% for rec in paraRecitals %}
          <a href="/r/#r{{ rec.number }}"
             class="block bg-surface-container-lowest rounded-xl p-4 hover:shadow-ambient transition-all group border-l-2 border-primary-fixed-dim">
            <div class="flex items-center justify-between mb-1">
              <p class="font-label text-xs font-medium text-primary">Recital {{ rec.number }}</p>
              <svg class="w-3.5 h-3.5 text-outline-variant group-hover:text-primary transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
              </svg>
            </div>
            <p class="font-body text-sm text-on-surface-variant italic line-clamp-4 group-hover:text-on-surface transition-colors">
              {{ rec.text | truncate(160) }}
            </p>
          </a>
          {% endfor %}
        </div>
        {% endif %}
      </div>
      {% endfor %}

      {# Prev / Next navigation #}
      <nav class="mt-12 max-w-3xl flex flex-col sm:flex-row gap-4 justify-between">
        {% if prevArt %}
        <a href="/{{ prevArt.number }}/"
           class="group flex items-center gap-3 bg-surface-container-lowest rounded-xl p-4 hover:shadow-ambient transition-all flex-1">
          <svg class="w-5 h-5 text-primary shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
          </svg>
          <div>
            <p class="article-tag">Previous</p>
            <p class="font-headline font-semibold text-sm text-on-surface group-hover:text-primary transition-colors">
              Article {{ prevArt.number }}{% if prevArt.title %}: {{ prevArt.title }}{% endif %}
            </p>
          </div>
        </a>
        {% else %}
        <div class="flex-1"></div>
        {% endif %}
        {% if nextArt %}
        <a href="/{{ nextArt.number }}/"
           class="group flex items-center gap-3 bg-surface-container-lowest rounded-xl p-4 hover:shadow-ambient transition-all flex-1 sm:text-right sm:flex-row-reverse">
          <svg class="w-5 h-5 text-primary shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
          <div>
            <p class="article-tag">Next</p>
            <p class="font-headline font-semibold text-sm text-on-surface group-hover:text-primary transition-colors">
              Article {{ nextArt.number }}{% if nextArt.title %}: {{ nextArt.title }}{% endif %}
            </p>
          </div>
        </a>
        {% endif %}
      </nav>
    </article>
  </div>
</div>
